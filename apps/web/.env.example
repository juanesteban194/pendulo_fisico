# ─── apps/web · variables de entorno ─────────────────────────────────────────

# URL del API en producción. En dev usamos rewrites de Next que apuntan a :4000.
# En prod (Vercel + Railway): apuntar al dominio del API (ej: https://api.pendulo.app).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Modo: 'development' | 'production' | 'test' (Next lo setea automáticamente)
# NODE_ENV=development
