# ─── apps/api · variables de entorno (producción) ────────────────────────────
# Copia como .env y ajusta los valores antes de desplegar en Railway.

PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# URL absoluta de la DB — Railway provee un volumen persistente en /app/data
DATABASE_URL="file:/app/data/prod.db"

# Dominios del frontend en Vercel (separados por coma)
# Ej: https://pendulo.vercel.app,https://pendulo-fisico.vercel.app
CORS_ORIGINS=https://pendulo.vercel.app

# Límite de rate (peticiones por segundo por IP)
RATE_LIMIT_MAX=20
