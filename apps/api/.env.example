# ─── apps/api · variables de entorno ────────────────────────────────────────

# Puerto del servidor Fastify (frontend espera 4000 por defecto)
PORT=4000

# Host: 0.0.0.0 expone en LAN (necesario para Docker/Railway). Para dev local,
# usar 127.0.0.1 si prefieres restringir al loopback.
HOST=0.0.0.0

# Modo: 'development' habilita logs detallados; 'production' los reduce
NODE_ENV=development

# CORS: orígenes permitidos separados por comas. En prod, agregar el dominio real.
CORS_ORIGINS=http://localhost:3000

# Conexión SQLite (ruta relativa a apps/api). El archivo se crea con la primera migración.
DATABASE_URL="file:./prisma/dev.db"

# Rate limit: requests/segundo por IP en endpoints sensibles
RATE_LIMIT_MAX=10
