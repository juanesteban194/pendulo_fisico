{
  "name": "pendulo-educativo",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma educativa Péndulo Físico — Universidad de Medellín · Física II · 2025-2",
  "scripts": {
    "dev":        "turbo run dev --parallel",
    "build":      "turbo run build",
    "test":       "turbo run test",
    "typecheck":  "turbo run typecheck",
    "lint":       "turbo run lint",
    "format":     "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "clean":      "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser":        "^7.18.0",
    "eslint":                            "^8.57.1",
    "prettier":                          "^3.3.3",
    "rimraf":                            "^6.0.1",
    "turbo":                             "^2.3.3",
    "typescript":                        "^5.6.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
