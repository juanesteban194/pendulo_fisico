{
  "name": "pendulum-simulator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":      "vite",
    "build":    "tsc && vite build",
    "preview":  "vite preview",
    "test":     "vitest run",
    "test:watch":    "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react":              "^18.3.1",
    "react-dom":          "^18.3.1",
    "@react-three/fiber": "^8.17.10",
    "@react-three/drei":  "^9.112.0",
    "three":              "^0.169.0",
    "zustand":            "^5.0.1",
    "recharts":           "^2.13.3"
  },
  "devDependencies": {
    "@types/react":           "^18.3.12",
    "@types/react-dom":       "^18.3.1",
    "@types/three":           "^0.169.0",
    "@vitejs/plugin-react":   "^4.3.3",
    "typescript":             "^5.6.3",
    "vite":                   "^5.4.11",
    "vitest":                 "^2.1.5",
    "@vitest/coverage-v8":    "^2.1.5",
    "jsdom":                  "^25.0.1"
  }
}